---
import '../styles/tokens.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import version from '../data/version.json';

interface Props {
  lang: 'pt' | 'en';
  title: string;
  description: string;
  /** path relativo dentro de /Transcritorio/ ex: 'pt/' ou 'en/' */
  path: string;
}

const { lang, title, description, path } = Astro.props;

const siteUrl = 'https://antrologos.github.io/Transcritorio';
const canonical = `${siteUrl}/${path}`;
const otherLang = lang === 'pt' ? 'en' : 'pt';
// Monta o path do outro idioma trocando o prefixo /pt/ ou /en/ pelo outro
const otherPath = lang === 'pt'
  ? path.replace(/^pt\//, 'en/')
  : path.replace(/^en\//, 'pt/');
const otherUrl = `${siteUrl}/${otherPath}`;

const htmlLang = lang === 'pt' ? 'pt-BR' : 'en-US';
const ogImage = `${siteUrl}/img/og-image.png`;
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0b111a" />
  <title>{title}</title>

  <!-- Canonical + hreflang -->
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="pt-BR" href={`${siteUrl}/pt/`} />
  <link rel="alternate" hreflang="en-US" href={`${siteUrl}/en/`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/pt/`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={htmlLang.replace('-', '_')} />
  <meta property="og:site_name" content="Transcritorio" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
  <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD SoftwareApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Transcritorio",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Windows, macOS, Linux",
    "softwareVersion": version.version,
    "description": description,
    "url": siteUrl,
    "license": "https://opensource.org/licenses/MIT",
    "author": {
      "@type": "Person",
      "name": "Rogerio Jeronimo Barbosa",
      "affiliation": "IESP-UERJ / CERES"
    },
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "BRL"
    }
  })} />
</head>
<body>
  <Nav lang={lang} otherUrl={otherUrl} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} version={version.version} />

  <!-- GoatCounter analytics (privacy-friendly, no cookies) -->
  <script
    data-goatcounter="https://transcritorio.goatcounter.com/count"
    async
    src="//gc.zgo.at/count.js"
  ></script>
</body>
</html>
