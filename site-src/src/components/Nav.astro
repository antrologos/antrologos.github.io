---
interface Props {
  lang: 'pt' | 'en';
  otherUrl: string;
}
const { lang, otherUrl } = Astro.props;
const isPt = lang === 'pt';

const labels = {
  features: isPt ? 'Recursos' : 'Features',
  how: isPt ? 'Como usar' : 'How to use',
  install: isPt ? 'Instalacao' : 'Install',
  requirements: isPt ? 'Requisitos' : 'Requirements',
  faq: 'FAQ',
};
---

<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href={`${import.meta.env.BASE_URL}/${lang}/`}>
      <span class="brand-dot"></span>
      Transcritório
    </a>
    <nav class="nav-links" aria-label={isPt ? 'Navegação' : 'Navigation'}>
      <a href="#features">{labels.features}</a>
      <a href="#how">{labels.how}</a>
      <a href="#install">{labels.install}</a>
      <a href="#requirements">{labels.requirements}</a>
      <a href="#faq">{labels.faq}</a>
    </nav>
    <div class="nav-right">
      <a class="lang-toggle" href={otherUrl} hreflang={isPt ? 'en-US' : 'pt-BR'} aria-label={isPt ? 'Switch to English' : 'Trocar para portugues'}>
        {isPt ? 'EN' : 'PT'}
      </a>
      <a class="gh" href="https://github.com/antrologos/Transcritorio" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.8-.25.8-.56v-2c-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.3-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.18-3.08-.12-.3-.52-1.47.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.12 3.05.73.8 1.17 1.82 1.17 3.08 0 4.42-2.68 5.38-5.24 5.67.41.36.78 1.06.78 2.14v3.18c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 17, 26, 0.85);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--spacing-l);
    padding-top: 12px;
    padding-bottom: 12px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--text-primary) !important;
    font-size: 17px;
    text-decoration: none !important;
  }
  .brand:hover { color: var(--accent) !important; }
  .brand-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent-soft);
  }
  .nav-links {
    display: flex;
    gap: var(--spacing-l);
    font-size: 14px;
    margin-left: auto;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .nav-links a:hover { color: var(--text-primary); }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .lang-toggle {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 6px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    color: var(--text-muted) !important;
    text-decoration: none !important;
  }
  .lang-toggle:hover { border-color: var(--accent); color: var(--accent) !important; }
  .gh {
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
  }
  .gh:hover { color: var(--accent); }
  @media (max-width: 720px) {
    .nav-links { display: none; }
  }
</style>
