---
interface Props {
  lang: 'pt' | 'en';
  version: string;
}
const { lang, version } = Astro.props;
const isPt = lang === 'pt';

const labels = {
  cite: isPt ? 'Como citar' : 'How to cite',
  bug: isPt ? 'Reportar bug' : 'Report a bug',
  contribute: isPt ? 'Contribuir no GitHub' : 'Contribute on GitHub',
  license: isPt ? 'Licença MIT' : 'MIT License',
  developedBy: isPt ? 'Desenvolvido por' : 'Developed by',
  credits: isPt
    ? 'Screenshots com trechos de entrevista pública do CPDOC-FGV (2011) com Wanderley Guilherme dos Santos (1935–2019).'
    : 'Screenshots feature excerpts from a public CPDOC-FGV interview (2011) with Wanderley Guilherme dos Santos (1935–2019).',
};
---

<footer>
  <div class="container footer-inner">
    <div class="footer-main">
      <div class="footer-brand">
        <strong>Transcritório</strong> v{version} · {labels.license}
      </div>
      <div class="footer-credit">
        {labels.developedBy} <a href="https://antrologos.github.io/" target="_blank" rel="noopener">Rogério Jerônimo Barbosa</a> · IESP-UERJ / CERES
      </div>
    </div>

    <div class="footer-links">
      <a href="https://github.com/antrologos/Transcritorio#how-to-cite" target="_blank" rel="noopener">{labels.cite}</a>
      <a href="https://github.com/antrologos/Transcritorio/issues" target="_blank" rel="noopener">{labels.bug}</a>
      <a href="https://github.com/antrologos/Transcritorio" target="_blank" rel="noopener">{labels.contribute}</a>
    </div>

    <p class="footer-credits">{labels.credits}</p>
  </div>
</footer>

<style>
  footer {
    padding: var(--spacing-xl) 0 var(--spacing-l);
    border-top: 1px solid var(--border);
    background: var(--bg-1);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-m);
  }
  .footer-main { display: flex; flex-direction: column; gap: 4px; }
  .footer-brand { font-size: 14px; color: var(--text-primary); }
  .footer-credit { font-size: 13px; color: var(--text-muted); }
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-l);
    font-size: 14px;
    padding: var(--spacing-m) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .footer-credits {
    font-size: 12px;
    color: var(--text-faint);
    margin: 0;
    line-height: 1.55;
  }
</style>
